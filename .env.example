# ===================================================================
# MLS + KHADANE™ Environment Variables
# Copy this file to .env.local for local development.
# Set these in Vercel dashboard for production.
# ===================================================================

# ─── ENQUIRY EMAIL (Resend) ─────────────────────────────────────────
# Get your API key from https://resend.com
# REQUIRED in production: if missing, /api/enquiry returns HTTP 503.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email addresses (must be verified senders in Resend)
ENQUIRY_FROM_EMAIL=enquiries@mohanlalsonsgroup.com
ENQUIRY_FROM_NAME=Mohan Lal & Sons

# Routing inboxes (per build prompt §4.4 + Section 10 single-channel lock)
INBOX_OFFICE_MLS=office@mohanlalsonsgroup.com
INBOX_KHADANE_EXPORTS=exports@khadane.com

# ─── DEV HOST MODE ──────────────────────────────────────────────────
# Used in local dev to lock the dev server to one site.
# Values: mls | khadane | (unset → defaults to MLS)
NEXT_PUBLIC_DEV_HOST_MODE=mls

# ─── PUBLIC SITE URLS ───────────────────────────────────────────────
NEXT_PUBLIC_MLS_URL=https://mohanlalsonsgroup.com
NEXT_PUBLIC_KHADANE_URL=https://khadane.com

# ─── OPTIONAL: CLOUDFLARE TURNSTILE ─────────────────────────────────
# Flagged in build prompt §4.4. Set both to enable CAPTCHA on enquiry form.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── ENVIRONMENT NAME ───────────────────────────────────────────────
# development | staging | production
APP_ENV=development
